# Libro Web Platform - Environment Configuration
# Copy this to .env and update values for your environment

# Application
APP_NAME="Libro Web Platform"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-string

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/libro_web

# Redis (for rate limiting/caching)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Groq AI API
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5368709120

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
